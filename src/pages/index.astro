---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import slugify from "@utils/slugify";
import { SOCIALS } from "@config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1>Lexing Daily Life</h1>
      <p>
        Software engineer, writer, and coach helping developers build better
        careers and healthier lives.
      </p>
    </section>

    <Hr />

    <section id="writing-cta" class="cta-card">
      <div class="cta-icon">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="48"
          height="48"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M19 2H5c-1.11 0-2 .9-2 2v16c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 6H6V6h12v2zm-4 4H6v-2h8v2zm4 4H6v-2h12v2z"
          ></path>
        </svg>
      </div>
      <h2>Read My Thoughts</h2>
      <p>
        Deep dives into compilers, interpreters, API design, and the craft of
        software engineering.
      </p>
      <LinkButton href="/posts">
        Browse All Posts
        <svg xmlns="http://www.w3.org/2000/svg"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </LinkButton>
    </section>

    <Hr />

    <section id="coaching-cta" class="cta-card">
      <div class="cta-icon">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="48"
          height="48"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 2L2 7v10c0 5.55 3.84 10.74 10 12 6.16-1.26 10-6.45 10-12V7l-10-5zm0 18.5c-4.28-.82-7.5-4.81-7.5-9.5V8.43l7.5-3.75 7.5 3.75V11c0 4.69-3.22 8.68-7.5 9.5zm-1-13.5h2v6h-2zm0 8h2v2h-2z"
          ></path>
        </svg>
      </div>
      <h2>Level Up Your Tech Career</h2>
      <p>
        10 years of engineering experience. Proven mentorship track record.
        Navigate your career journey—from interview prep to senior-level
        transitions.
      </p>
      <LinkButton href="/coaching">
        Explore Career Coaching
        <svg xmlns="http://www.w3.org/2000/svg"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </LinkButton>
    </section>

    <Hr />

    <section id="run-coaching-cta" class="cta-card">
      <div class="cta-icon">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="48"
          height="48"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z"
          ></path>
        </svg>
      </div>
      <h2>Escape the Chair</h2>
      <p>
        Desk-bound? Mental fog? I've been there. Running transformed my health
        as a developer— better focus, less stress, more energy.
      </p>
      <LinkButton href="/run-coaching">
        Explore Run Coaching
        <svg xmlns="http://www.w3.org/2000/svg"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </LinkButton>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-6 pt-8;
  }
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }
  #hero p {
    @apply my-4 text-lg opacity-80;
  }

  /* ===== CTA Cards ===== */
  .cta-card {
    @apply pb-6 pt-12;
  }
  .cta-icon {
    @apply mb-6;
  }
  .cta-icon svg {
    @apply fill-skin-accent;
  }
  .cta-card h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .cta-card p {
    @apply my-4;
  }
  .cta-card a {
    @apply underline decoration-2 underline-offset-4;
  }
</style>
